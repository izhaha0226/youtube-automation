    },
    {
      "idx": 85,
      "text": "다음으로 봐야 할 건,",
      "start_ms": 162458,
      "end_ms": 164261
    },
    {
      "idx": 86,
      "text": "*거래량*입니다.",
      "start_ms": 164261,
      "end_ms": 165613
    },
    {
      "idx": 87,
      "text": "이 지표가 정말 중요합니다.",
      "start_ms": 165613,
      "end_ms": 167867
    },
    {
      "idx": 88,
      "text": "가격은 겉으로 보면,",
      "start_ms": 167867,
      "end_ms": 169520
    },
    {
      "idx": 89,
      "text": "버티는 것처럼 보일 수 있습니다.",
      "start_ms": 169520,
      "end_ms": 172225
    },
    {
      "idx": 90,
      "text": "호가도 안 떨어지고,",
      "start_ms": 172225,
      "end_ms": 173878
    },
    {
      "idx": 91,
      "text": "급매도 줄어든 것처럼 보일 수 있죠.",
      "start_ms": 173878,
      "end_ms": 176884
    },
    {
      "idx": 92,
      "text": "그런데 거래량이 살아나지 않으면,",
      "start_ms": 176884,
      "end_ms": 179589
    },
    {
      "idx": 93,
      "text": "시장 체온은 아직 낮습니다.",
      "start_ms": 179589,
      "end_ms": 181843
    },
    {
      "idx": 94,
      "text": "쉽게 말해,",
      "start_ms": 181843,
      "end_ms": 182744
    },
    {
      "idx": 95,
      "text": "가격은 서 있는데,",
      "start_ms": 182744,
      "end_ms": 184247
    },
    {
      "idx": 96,
      "text": "사람들이 실제로 안 사고 있다는 뜻입니다.",
      "start_ms": 184247,
      "end_ms": 187704
    },
    {
      "idx": 97,
      "text": "이건 굉장히 중요합니다.",
      "start_ms": 187704,
      "end_ms": 189658
    },
    {
      "idx": 98,
      "text": "왜냐하면 시장의 방향은,",
      "start_ms": 189658,
      "end_ms": 191612
    },
    {
      "idx": 99,
      "text": "결국 거래가 말해주기 때문입니다.",
      "start_ms": 191612,
      "end_ms": 194317
    },
    {
      "idx": 100,
      "text": "말이 아니라,",
      "start_ms": 194317,
      "end_ms": 195369
    },
    {
      "idx": 101,
      "text": "체결이 말해줍니다.",
      "start_ms": 195369,
      "end_ms": 196872
    },
    {
      "idx": 102,
      "text": "분위기가 아니라,",
      "start_ms": 196872,
      "end_ms": 198224
    },
    {
      "idx": 103,
      "text": "매수 행동이 말해줍니다.",
      "start_ms": 198224,
      "end_ms": 200178
    },
    {
      "idx": 104,
      "text": "거래량이 받쳐주지 않으면,",
      "start_ms": 200178,
      "end_ms": 202282
    },
    {
      "idx": 105,
      "text": "가격 반등은 넓게 퍼지기 어렵습니다.",
      "start_ms": 202282,
      "end_ms": 205288
    },
    {
      "idx": 106,
      "text": "잠깐 버틸 수는 있어도,",
      "start_ms": 205288,
      "end_ms": 207242
    },
    {
      "idx": 107,
      "text": "추세가 되긴 어렵습니다.",
      "start_ms": 207242,
      "end_ms": 209196
    },
    {
      "idx": 108,
      "text": "특히 실수요자는,",
      "start_ms": 209196,
      "end_ms": 210548
    },
    {
      "idx": 109,
      "text": "예전보다 훨씬 더 꼼꼼합니다.",
      "start_ms": 210548,
      "end_ms": 212953
    },
    {
      "idx": 110,
      "text": "금리만 보지 않습니다.",
      "start_ms": 212953,
      "end_ms": 214756
    },
    {
      "idx": 111,
      "text": "대출 가능 금액을 보고,",
      "start_ms": 214756,
      "end_ms": 216710
    },
    {
      "idx": 112,
      "text": "지역별 공급도 보고,",
      "start_ms": 216710,
      "end_ms": 218363
    },
    {
      "idx": 113,
      "text": "전세가격 흐름도 같이 봅니다.",
      "start_ms": 218363,
      "end_ms": 220768
    },
    {
      "idx": 114,
      "text": "내가 이 집을 샀을 때,",
      "start_ms": 220768,
      "end_ms": 222722
    },
    {
      "idx": 115,
      "text": "전세가 받쳐주는지.",
      "start_ms": 222722,
      "end_ms": 224225
    },
    {
      "idx": 116,
      "text": "입주 물량이 많은지.",
      "start_ms": 224225,
      "end_ms": 225878
    },
    {
      "idx": 117,
      "text": "앞으로 가격이 아니라,",
      "start_ms": 225878,
      "end_ms": 227681
    },
    {
      "idx": 118,
      "text": "현금흐름이 괜찮은지.",
      "start_ms": 227681,
      "end_ms": 229334
    },
    {
      "idx": 119,
      "text": "이걸 같이 봅니다.",
      "start_ms": 229334,
      "end_ms": 230837
    },
    {
      "idx": 120,
      "text": "그러니까 일부 선호 지역이,",
      "start_ms": 230837,
      "end_ms": 233091
    },
    {
      "idx": 121,
      "text": "버티거나 오른다고 해서,",
      "start_ms": 233091,
      "end_ms": 235045
    },
    {
      "idx": 122,
      "text": "전체 시장이 살아났다고,",
      "start_ms": 235045,
      "end_ms": 236999
    },
    {
      "idx": 123,
      "text": "바로 말하긴 어렵습니다.",
      "start_ms": 236999,
      "end_ms": 238953
    },
    {
      "idx": 124,
      "text": "전체 시장으로 보면,",
      "start_ms": 238953,
      "end_ms": 240606
    },
    {
      "idx": 125,
      "text": "금리 동결만으로,",
      "start_ms": 240606,
      "end_ms": 241958
    },
    {
      "idx": 126,
      "text": "상승장이 시작됐다고 보기 어렵습니다.",
      "start_ms": 241958,
      "end_ms": 244964
    },
    {
      "idx": 127,
      "text": "그 정도로 지금 시장은,",
      "start_ms": 244964,
      "end_ms": 246918
    },
    {
      "idx": 128,
      "text": "훨씬 더 선별적으로 움직입니다.",
      "start_ms": 246918,
      "end_ms": 249473
    },
    {
      "idx": 129,
      "text": "사례를 떠올려보면,",
      "start_ms": 249473,
      "end_ms": 250976
    },
    {
      "idx": 130,
      "text": "더 분명합니다.",
      "start_ms": 250976,
      "end_ms": 252178
    },
    {
      "idx": 131,
      "text": "같은 금리 환경에서도,",
      "start_ms": 252178,
      "end_ms": 253981
    },
    {
      "idx": 132,
      "text": "서울 핵심지와 외곽은,",
      "start_ms": 253981,
      "end_ms": 255784
    },
    {
      "idx": 133,
      "text": "반응이 다릅니다.",
      "start_ms": 255784,
      "end_ms": 257136
    },
    {
      "idx": 134,
      "text": "수도권과 지방도,",
      "start_ms": 257136,
      "end_ms": 258488
    },
    {
      "idx": 135,
      "text": "반응이 다릅니다.",
      "start_ms": 258488,
      "end_ms": 259840
    },
    {
      "idx": 136,
      "text": "수요가 몰리는 곳은,",
      "start_ms": 259840,
      "end_ms": 261493
    },
    {
      "idx": 137,
      "text": "거래가 조금만 붙어도,",
      "start_ms": 261493,
      "end_ms": 263296
    },
    {
      "idx": 138,
      "text": "가격이 버팁니다.",
      "start_ms": 263296,
      "end_ms": 264648
    },
    {
      "idx": 139,
      "text": "사고 싶은 사람이,",
      "start_ms": 264648,
      "end_ms": 266151
    },
    {
      "idx": 140,
      "text": "원래 많은 곳이기 때문입니다.",
      "start_ms": 266151,
      "end_ms": 268556
    },
    {
      "idx": 141,
      "text": "반대로 수요가 약한 곳은,",
      "start_ms": 268556,
      "end_ms": 270660
    },
    {
      "idx": 142,
      "text": "금리가 멈춰도,",
      "start_ms": 270660,
      "end_ms": 271862
    },
    {
      "idx": 143,
      "text": "거래가 잘 붙지 않습니다.",
      "start_ms": 271862,
      "end_ms": 273966
    },
    {
      "idx": 144,
      "text": "사고 싶은 사람보다,",
      "start_ms": 273966,
      "end_ms": 275619
    },
    {
      "idx": 145,
      "text": "망설이는 사람이 많기 때문입니다.",
      "start_ms": 275619,
      "end_ms": 278324
    },
    {
      "idx": 146,
      "text": "여기서 시장의 본질이 보입니다.",
      "start_ms": 278324,
      "end_ms": 280879
    },
    {
      "idx": 147,
      "text": "지금 시장은,",
      "start_ms": 280879,
      "end_ms": 281931
    },
    {
      "idx": 148,
      "text": "금리 하나로,",
      "start_ms": 281931,
      "end_ms": 282983
    },
    {
      "idx": 149,
      "text": "같이 움직이는 장이 아닙니다.",
      "start_ms": 282983,
      "end_ms": 285388
    },
    {
      "idx": 150,
      "text": "*자금 여력*과,",
      "start_ms": 285388,
      "end_ms": 286740
    },
    {
      "idx": 151,
      "text": "*입지*에 따라,",
      "start_ms": 286740,
      "end_ms": 288092
    },
    {
      "idx": 152,
      "text": "갈라지는 장입니다.",
      "start_ms": 288092,
      "end_ms": 289595
    },
    {
      "idx": 153,
      "text": "한마디로,",
      "start_ms": 289595,
      "end_ms": 290346
    },
    {
      "idx": 154,
      "text": "선별 장세에 가깝습니다.",
      "start_ms": 290346,
      "end_ms": 292300
    },
    {
      "idx": 155,
      "text": "좋은 곳은 버티고,",
      "start_ms": 292300,
      "end_ms": 293803
    },
    {
      "idx": 156,
      "text": "약한 곳은 계속 조심스럽습니다.",
      "start_ms": 293803,
      "end_ms": 296358
    },
    {
      "idx": 157,
      "text": "이 차이가 점점 더 커집니다.",
      "start_ms": 296358,
      "end_ms": 298763
    },
    {
      "idx": 158,
      "text": "그래서 지금은,",
      "start_ms": 298763,
      "end_ms": 299965
    },
    {
      "idx": 159,
      "text": "질문을 바꿔야 합니다.",
      "start_ms": 299965,
      "end_ms": 301768
    },
    {
      "idx": 160,
      "text": "금리가 멈췄는데,",
      "start_ms": 301768,
      "end_ms": 303120
    },
    {
      "idx": 161,
      "text": "왜 집값이 안 오르지.",
      "start_ms": 303120,
      "end_ms": 304923
    },
    {
      "idx": 162,
      "text": "이 질문도 중요합니다.",
      "start_ms": 304923,
      "end_ms": 306726
    },
    {
      "idx": 163,
      "text": "하지만 더 중요한 질문은,",
      "start_ms": 306726,
      "end_ms": 308830
    },
    {
      "idx": 164,
      "text": "어디가 먼저 반응하느냐입니다.",
      "start_ms": 308830,
      "end_ms": 311235
    },
    {
      "idx": 165,
      "text": "누가 먼저 움직이느냐입니다.",
      "start_ms": 311235,
      "end_ms": 313489
    },
    {
      "idx": 166,
      "text": "현금 여력이 있는 수요가,",
      "start_ms": 313489,
      "end_ms": 315593
    },
    {
      "idx": 167,
      "text": "어느 지역에 붙는지.",
      "start_ms": 315593,
      "end_ms": 317246
    },
    {
      "idx": 168,
      "text": "대출이 실제로 풀리는 구간이,",
      "start_ms": 317246,
      "end_ms": 319651
    },
    {
      "idx": 169,
      "text": "어디인지.",
      "start_ms": 319651,
      "end_ms": 320402
    },
    {
      "idx": 170,
      "text": "전세가가 받쳐주는 곳이,",
      "start_ms": 320402,
      "end_ms": 322356
    },
    {
      "idx": 171,
      "text": "어딘지.",
      "start_ms": 322356,
      "end_ms": 322957
    },
    {
      "idx": 172,
      "text": "공급 부담이 적은 곳이,",
      "start_ms": 322957,
      "end_ms": 324911
    },
    {
      "idx": 173,
      "text": "어딘지.",
      "start_ms": 324911,
      "end_ms": 325512
    },
    {
      "idx": 174,
      "text": "이걸 봐야 합니다.",
      "start_ms": 325512,
      "end_ms": 327015
    },
    {
      "idx": 175,
      "text": "이제 시장은,",
      "start_ms": 327015,
      "end_ms": 328067
    },
    {
      "idx": 176,
      "text": "한 줄 뉴스로 설명되지 않습니다.",
      "start_ms": 328067,
      "end_ms": 330772
    },
    {
      "idx": 177,
      "text": "기준금리 한 줄로,",
      "start_ms": 330772,
      "end_ms": 332275
    },
    {
      "idx": 178,
      "text": "전체가 움직이던 시기가 있었죠.",
      "start_ms": 332275,
      "end_ms": 334830
    },
    {
      "idx": 179,
      "text": "하지만 지금은 아닙니다.",
      "start_ms": 334830,
      "end_ms": 336784
    },
    {
      "idx": 180,
      "text": "지금은 훨씬 복합적입니다.",
      "start_ms": 336784,
      "end_ms": 338888
    },
    {
      "idx": 181,
      "text": "금리와 대출,",
      "start_ms": 338888,
      "end_ms": 339940
    },
    {
      "idx": 182,
      "text": "거래량과 수급,",
      "start_ms": 339940,
      "end_ms": 341142
    },
    {
      "idx": 183,
      "text": "그리고 경기 기대가,",
      "start_ms": 341142,
      "end_ms": 342795
    },
    {
      "idx": 184,
      "text": "같이 움직입니다.",
      "start_ms": 342795,
      "end_ms": 344147
    },
    {
      "idx": 185,
      "text": "특히 경기 기대는,",
      "start_ms": 344147,
      "end_ms": 345650
    },
    {
      "idx": 186,
      "text": "절대 가볍지 않습니다.",
      "start_ms": 345650,
      "end_ms": 347453
    },
    {
      "idx": 187,
      "text": "사람들은 집을 살 때,",
      "start_ms": 347453,
      "end_ms": 349256
    },
    {
      "idx": 188,
      "text": "가격만 보지 않습니다.",
      "start_ms": 349256,
      "end_ms": 351059
    },
    {
      "idx": 189,
      "text": "앞으로 내 직장이 안정적인지,",
      "start_ms": 351059,
      "end_ms": 353464
    },
    {
      "idx": 190,
      "text": "소득이 유지될지,",
      "start_ms": 353464,
      "end_ms": 354816
    },
    {
      "idx": 191,
      "text": "갑자기 지출이 늘진 않을지,",
      "start_ms": 354816,
      "end_ms": 357070
    },
    {
      "idx": 192,
      "text": "이런 것도 같이 봅니다.",
      "start_ms": 357070,
      "end_ms": 359024
    },
    {
      "idx": 193,
      "text": "기준금리가 그대로라고 해도,",
      "start_ms": 359024,
      "end_ms": 361278
    },
    {
      "idx": 194,
      "text": "경기에 대한 확신이 약하면,",
      "start_ms": 361278,
      "end_ms": 363532
    },
    {
      "idx": 195,
      "text": "큰 대출을 일으키기 어렵습니다.",
      "start_ms": 363532,
      "end_ms": 366087
    },
    {
      "idx": 196,
      "text": "이건 아주 현실적인 판단입니다.",
      "start_ms": 366087,
      "end_ms": 368642
    },
    {
      "idx": 197,
      "text": "지금은 공격적으로 들어가기보다,",
      "start_ms": 368642,
      "end_ms": 371197
    },
    {
      "idx": 198,
      "text": "확실한 신호를 기다리는 사람이 많습니다.",
      "start_ms": 371197,
      "end_ms": 374504
    },
    {
      "idx": 199,
      "text": "그래서 시장이,",
      "start_ms": 374504,
      "end_ms": 375706
    },
    {
      "idx": 200,
      "text": "생각보다 천천히 움직입니다.",
      "start_ms": 375706,
      "end_ms": 377960
    },
    {
      "idx": 201,
      "text": "겉으로는 조용한데,",
      "start_ms": 377960,
      "end_ms": 379463
    },
    {
      "idx": 202,
      "text": "속에서는 아주 예민하게,",
      "start_ms": 379463,
      "end_ms": 381417
    },
    {
      "idx": 203,
      "text": "신호를 고르고 있는 겁니다.",
      "start_ms": 381417,
      "end_ms": 383671
    },
    {
      "idx": 204,
      "text": "또 하나 봐야 할 건,",
      "start_ms": 383671,
      "end_ms": 385474
    },
    {
      "idx": 205,
      "text": "심리의 방향입니다.",
      "start_ms": 385474,
      "end_ms": 386977
    },
    {
      "idx": 206,
      "text": "부동산 시장은,",
      "start_ms": 386977,
      "end_ms": 388179
    },
    {
      "idx": 207,
      "text": "늘 기대와 불안이 같이 갑니다.",
      "start_ms": 388179,
      "end_ms": 390734
    },
    {
      "idx": 208,
      "text": "금리 동결은 분명,",
      "start_ms": 390734,
      "end_ms": 392237
    },
    {
      "idx": 209,
      "text": "나쁜 뉴스만은 아닙니다.",
      "start_ms": 392237,
      "end_ms": 394191
    },
    {
      "idx": 210,
      "text": "그렇다고 바로,",
      "start_ms": 394191,
      "end_ms": 395393
    },
    {
      "idx": 211,
      "text": "강한 호재도 아닙니다.",
      "start_ms": 395393,
      "end_ms": 397196
    },
    {
      "idx": 212,
      "text": "왜냐하면 동결이라는 건,",
      "start_ms": 397196,
      "end_ms": 399150
    },
    {
      "idx": 213,
      "text": "좋아서 멈춘 것일 수도 있지만,",
      "start_ms": 399150,
      "end_ms": 401705
    },
    {
      "idx": 214,
      "text": "아직 확신이 없어서,",
      "start_ms": 401705,
      "end_ms": 403358
    },
    {
      "idx": 215,
      "text": "멈춘 것일 수도 있기 때문입니다.",
      "start_ms": 403358,
      "end_ms": 406063
    },
    {
      "idx": 216,
      "text": "지금 시장은,",
      "start_ms": 406063,
      "end_ms": 407115
    },
    {
      "idx": 217,
      "text": "후자에 더 가깝게 해석합니다.",
      "start_ms": 407115,
      "end_ms": 409520
    },
    {
      "idx": 218,
      "text": "좋아서 달리는 장이라기보다,",
      "start_ms": 409520,
      "end_ms": 411774
    },
    {
      "idx": 219,
      "text": "조심스럽게 확인하는 장입니다.",
      "start_ms": 411774,
      "end_ms": 414179
    },
    {
      "idx": 220,
      "text": "그래서 반응도,",
      "start_ms": 414179,
      "end_ms": 415381
    },
    {
      "idx": 221,
      "text": "지역별로 나뉘고,",
      "start_ms": 415381,
      "end_ms": 416733
    },
    {
      "idx": 222,
      "text": "수요층별로 나뉘고,",
      "start_ms": 416733,
      "end_ms": 418236
    },
    {
      "idx": 223,
      "text": "가격대별로도 나뉩니다.",
      "start_ms": 418236,
      "end_ms": 420039
    },
    {
      "idx": 224,
      "text": "정리해보겠습니다.",
      "start_ms": 420039,
      "end_ms": 421391
    },
    {
      "idx": 225,
      "text": "*기준금리 2.5% 유지* 자체는,",
      "start_ms": 421391,
      "end_ms": 424247
    },
    {
      "idx": 226,
      "text": "무조건 호재도 아니고,",
      "start_ms": 424247,
      "end_ms": 426050
    },
    {
      "idx": 227,
      "text": "무조건 악재도 아닙니다.",
      "start_ms": 426050,
      "end_ms": 428004
    },
    {
      "idx": 228,
      "text": "오히려 시장이 아직,",
      "start_ms": 428004,
      "end_ms": 429657
    },
    {
      "idx": 229,
      "text": "확신을 못 갖고 있다는,",
      "start_ms": 429657,
      "end_ms": 431611
    },
    {
      "idx": 230,
      "text": "신호에 가깝습니다.",
      "start_ms": 431611,
      "end_ms": 433114
    },
    {
      "idx": 231,
      "text": "집값을 움직이는 건 이제,",
      "start_ms": 433114,
      "end_ms": 435218
    },
    {
      "idx": 232,
      "text": "기준금리 한 줄이 아닙니다.",
      "start_ms": 435218,
      "end_ms": 437472
    },
    {
      "idx": 233,
      "text": "*대출금리*가 중요하고,",
      "start_ms": 437472,
      "end_ms": 439426
    },
    {
      "idx": 234,
      "text": "*거래량*이 중요하고,",
      "start_ms": 439426,
      "end_ms": 441229
    },
    {
      "idx": 235,
      "text": "지역별 *수급*이 중요합니다.",
      "start_ms": 441229,
      "end_ms": 443634
    },
    {
      "idx": 236,
      "text": "그리고 경기 회복에 대한,",
      "start_ms": 443634,
      "end_ms": 445738
    },
    {
      "idx": 237,
      "text": "*기대*도 중요합니다.",
      "start_ms": 445738,
      "end_ms": 447541
    },
    {
      "idx": 238,
      "text": "결국 지금은,",
      "start_ms": 447541,
      "end_ms": 448593
    },
    {
      "idx": 239,
      "text": "금리만 보는 시각보다,",
      "start_ms": 448593,
      "end_ms": 450396
    },
    {
      "idx": 240,
      "text": "시장이 어디에서,",
      "start_ms": 450396,
      "end_ms": 451748
    },
    {
      "idx": 241,
      "text": "먼저 반응하는지 읽는 시각이,",
      "start_ms": 451748,
      "end_ms": 454153
    },
    {
      "idx": 242,
      "text": "훨씬 중요합니다.",
      "start_ms": 454153,
      "end_ms": 455505
    },
    {
      "idx": 243,
      "text": "뉴스 headline보다,",
      "start_ms": 455505,
      "end_ms": 457609
    },
    {
      "idx": 244,
      "text": "현장의 흐름을 봐야 합니다.",
      "start_ms": 457609,
      "end_ms": 459863
    },
    {
      "idx": 245,
      "text": "숫자 한 개보다,",
      "start_ms": 459863,
      "end_ms": 461215
    },
    {
      "idx": 246,
      "text": "연결된 신호를 같이 봐야 합니다.",
      "start_ms": 461215,
      "end_ms": 463920
    },
    {
      "idx": 247,
      "text": "그래야 지금 시장을,",
      "start_ms": 463920,
      "end_ms": 465573
    },
    {
      "idx": 248,
      "text": "조금 더 정확하게 볼 수 있습니다.",
      "start_ms": 465573,
      "end_ms": 468429
    },
    {
      "idx": 249,
      "text": "여러분 지역은 어떻습니까.",
      "start_ms": 468429,
      "end_ms": 470533
    },
    {
      "idx": 250,
      "text": "거래가 조금씩 살아나고 있나요.",
      "start_ms": 470533,
      "end_ms": 473088
    },
    {
      "idx": 251,
      "text": "아니면 아직 조용한가요.",
      "start_ms": 473088,
      "end_ms": 475042
    },
    {
      "idx": 252,
      "text": "여러분 지역은,",
      "start_ms": 475042,
      "end_ms": 476244
    },
    {
      "idx": 253,
      "text": "어떤 영향을 받고 있는지,",
      "start_ms": 476244,
      "end_ms": 478348
    },
    {
      "idx": 254,
      "text": "댓글로 남겨주세요.",
      "start_ms": 478348,
      "end_ms": 479851
    }
  ]
}
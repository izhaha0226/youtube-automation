      "start_ms": 132157,
      "end_ms": 134879
    },
    {
      "idx": 43,
      "text": "여기서 **규제 변수**도",
      "start_ms": 134879,
      "end_ms": 139113
    },
    {
      "idx": 44,
      "text": "매우 중요합니다.",
      "start_ms": 139113,
      "end_ms": 141835
    },
    {
      "idx": 45,
      "text": "부동산은 금리만으로",
      "start_ms": 141835,
      "end_ms": 144859
    },
    {
      "idx": 46,
      "text": "움직이지 않습니다.",
      "start_ms": 144859,
      "end_ms": 147883
    },
    {
      "idx": 47,
      "text": "대출 규제, 세금,",
      "start_ms": 147883,
      "end_ms": 150907
    },
    {
      "idx": 48,
      "text": "정책 메시지에 따라",
      "start_ms": 150907,
      "end_ms": 153931
    },
    {
      "idx": 49,
      "text": "시장 온도는 바로",
      "start_ms": 153931,
      "end_ms": 156653
    },
    {
      "idx": 50,
      "text": "달라집니다.",
      "start_ms": 156653,
      "end_ms": 158467
    },
    {
      "idx": 51,
      "text": "만약 시장이",
      "start_ms": 158467,
      "end_ms": 160281
    },
    {
      "idx": 52,
      "text": "규제 완화로 받아들이면,",
      "start_ms": 160281,
      "end_ms": 164212
    },
    {
      "idx": 53,
      "text": "가격보다 먼저 기대감이",
      "start_ms": 164212,
      "end_ms": 167841
    },
    {
      "idx": 54,
      "text": "반응할 수 있습니다.",
      "start_ms": 167841,
      "end_ms": 171168
    },
    {
      "idx": 55,
      "text": "반대로 가계부채 관리나",
      "start_ms": 171168,
      "end_ms": 174797
    },
    {
      "idx": 56,
      "text": "대출 통제가 강조되면,",
      "start_ms": 174797,
      "end_ms": 178426
    },
    {
      "idx": 57,
      "text": "거래부터 다시",
      "start_ms": 178426,
      "end_ms": 180543
    },
    {
      "idx": 58,
      "text": "움츠러들 수 있습니다.",
      "start_ms": 180543,
      "end_ms": 184172
    },
    {
      "idx": 59,
      "text": "그래서 5월 9일 이후를",
      "start_ms": 184172,
      "end_ms": 188103
    },
    {
      "idx": 60,
      "text": "볼 때는,",
      "start_ms": 188103,
      "end_ms": 189615
    },
    {
      "idx": 61,
      "text": "집값 숫자보다 먼저",
      "start_ms": 189615,
      "end_ms": 192639
    },
    {
      "idx": 62,
      "text": "정책 신호를 읽어야 합니다.",
      "start_ms": 192639,
      "end_ms": 197175
    },
    {
      "idx": 63,
      "text": "시장에 보내는 메시지가",
      "start_ms": 197175,
      "end_ms": 200804
    },
    {
      "idx": 64,
      "text": "완화인지,",
      "start_ms": 200804,
      "end_ms": 202316
    },
    {
      "idx": 65,
      "text": "관리인지.",
      "start_ms": 202316,
      "end_ms": 203828
    },
    {
      "idx": 66,
      "text": "그 차이가 매우 큽니다.",
      "start_ms": 203828,
      "end_ms": 207759
    },
    {
      "idx": 67,
      "text": "이제 시나리오로",
      "start_ms": 207759,
      "end_ms": 210178
    },
    {
      "idx": 68,
      "text": "보겠습니다.",
      "start_ms": 210178,
      "end_ms": 211992
    },
    {
      "idx": 69,
      "text": "첫 번째입니다.",
      "start_ms": 211992,
      "end_ms": 214411
    },
    {
      "idx": 70,
      "text": "금리는 멈췄고,",
      "start_ms": 214411,
      "end_ms": 216830
    },
    {
      "idx": 71,
      "text": "규제 부담도 크지 않다.",
      "start_ms": 216830,
      "end_ms": 220761
    },
    {
      "idx": 72,
      "text": "이 경우엔 선호 지역,",
      "start_ms": 220761,
      "end_ms": 224390
    },
    {
      "idx": 73,
      "text": "핵심 입지부터",
      "start_ms": 224390,
      "end_ms": 226507
    },
    {
      "idx": 74,
      "text": "거래가 살아날 수 있습니다.",
      "start_ms": 226507,
      "end_ms": 231043
    },
    {
      "idx": 75,
      "text": "가격은 크게 뛰지 않아도,",
      "start_ms": 231043,
      "end_ms": 235277
    },
    {
      "idx": 76,
      "text": "먼저 버티거나",
      "start_ms": 235277,
      "end_ms": 237394
    },
    {
      "idx": 77,
      "text": "제한적으로 오를 수 있습니다.",
      "start_ms": 237394,
      "end_ms": 242233
    },
    {
      "idx": 78,
      "text": "두 번째입니다.",
      "start_ms": 242233,
      "end_ms": 244652
    },
    {
      "idx": 79,
      "text": "금리는 멈췄지만,",
      "start_ms": 244652,
      "end_ms": 247374
    },
    {
      "idx": 80,
      "text": "규제가 강화되거나",
      "start_ms": 247374,
      "end_ms": 250096
    },
    {
      "idx": 81,
      "text": "대출 문턱이 높아진다.",
      "start_ms": 250096,
      "end_ms": 253725
    },
    {
      "idx": 82,
      "text": "그러면 매수 대기 수요는",
      "start_ms": 253725,
      "end_ms": 257656
    },
    {
      "idx": 83,
      "text": "다시 관망으로 돌아섭니다.",
      "start_ms": 257656,
      "end_ms": 261890
    },
    {
      "idx": 84,
      "text": "이때는 가격보다",
      "start_ms": 261890,
      "end_ms": 264309
    },
    {
      "idx": 85,
      "text": "거래량이 먼저 식습니다.",
      "start_ms": 264309,
      "end_ms": 268240
    },
    {
      "idx": 86,
      "text": "체감상 시장이",
      "start_ms": 268240,
      "end_ms": 270357
    },
    {
      "idx": 87,
      "text": "조용해집니다.",
      "start_ms": 270357,
      "end_ms": 272474
    },
    {
      "idx": 88,
      "text": "세 번째입니다.",
      "start_ms": 272474,
      "end_ms": 274893
    },
    {
      "idx": 89,
      "text": "전국 평균은 조용합니다.",
      "start_ms": 274893,
      "end_ms": 278824
    },
    {
      "idx": 90,
      "text": "그런데 서울 핵심지와",
      "start_ms": 278824,
      "end_ms": 282151
    },
    {
      "idx": 91,
      "text": "일부 수도권은 강합니다.",
      "start_ms": 282151,
      "end_ms": 286082
    },
    {
      "idx": 92,
      "text": "반대로 지방이나 외곽은",
      "start_ms": 286082,
      "end_ms": 289711
    },
    {
      "idx": 93,
      "text": "약합니다.",
      "start_ms": 289711,
      "end_ms": 291223
    },
    {
      "idx": 94,
      "text": "완전히 **분화된 시장**이",
      "start_ms": 291223,
      "end_ms": 295759
    },
    {
      "idx": 95,
      "text": "이어지는 그림입니다.",
      "start_ms": 295759,
      "end_ms": 299086
    },
    {
      "idx": 96,
      "text": "저는 지금 이 세 번째가",
      "start_ms": 299086,
      "end_ms": 303017
    },
    {
      "idx": 97,
      "text": "가장 현실적이라고 봅니다.",
      "start_ms": 303017,
      "end_ms": 307251
    },
    {
      "idx": 98,
      "text": "이미 비슷한 흐름은",
      "start_ms": 307251,
      "end_ms": 310275
    },
    {
      "idx": 99,
      "text": "여러 번 나왔습니다.",
      "start_ms": 310275,
      "end_ms": 313602
    },
    {
      "idx": 100,
      "text": "같은 금리 환경이어도,",
      "start_ms": 313602,
      "end_ms": 317231
    },
    {
      "idx": 101,
      "text": "일자리와 학군이",
      "start_ms": 317231,
      "end_ms": 319650
    },
    {
      "idx": 102,
      "text": "받쳐주는 곳은",
      "start_ms": 319650,
      "end_ms": 321767
    },
    {
      "idx": 103,
      "text": "거래가 붙습니다.",
      "start_ms": 321767,
      "end_ms": 324489
    },
    {
      "idx": 104,
      "text": "교통 개선 기대가 있는 곳도",
      "start_ms": 324489,
      "end_ms": 329025
    },
    {
      "idx": 105,
      "text": "먼저 반응합니다.",
      "start_ms": 329025,
      "end_ms": 331747
    },
    {
      "idx": 106,
      "text": "반대로 입주 물량 부담이",
      "start_ms": 331747,
      "end_ms": 335678
    },
    {
      "idx": 107,
      "text": "큰 곳.",
      "start_ms": 335678,
      "end_ms": 336887
    },
    {
      "idx": 108,
      "text": "수요 기반이 약한 곳.",
      "start_ms": 336887,
      "end_ms": 340516
    },
    {
      "idx": 109,
      "text": "이런 지역은 회복 속도가",
      "start_ms": 340516,
      "end_ms": 344447
    },
    {
      "idx": 110,
      "text": "훨씬 느립니다.",
      "start_ms": 344447,
      "end_ms": 346866
    },
    {
      "idx": 111,
      "text": "결국 경제와 부동산은",
      "start_ms": 346866,
      "end_ms": 350193
    },
    {
      "idx": 112,
      "text": "따로 가지 않습니다.",
      "start_ms": 350193,
      "end_ms": 353520
    },
    {
      "idx": 113,
      "text": "금리가 멈췄다고",
      "start_ms": 353520,
      "end_ms": 355939
    },
    {
      "idx": 114,
      "text": "바로 오르는 것도",
      "start_ms": 355939,
      "end_ms": 358661
    },
    {
      "idx": 115,
      "text": "아닙니다.",
      "start_ms": 358661,
      "end_ms": 360173
    },
    {
      "idx": 116,
      "text": "규제가 나왔다고",
      "start_ms": 360173,
      "end_ms": 362592
    },
    {
      "idx": 117,
      "text": "무조건 급락하는 것도",
      "start_ms": 362592,
      "end_ms": 365919
    },
    {
      "idx": 118,
      "text": "아닙니다.",
      "start_ms": 365919,
      "end_ms": 367431
    },
    {
      "idx": 119,
      "text": "실제 시장은",
      "start_ms": 367431,
      "end_ms": 369245
    },
    {
      "idx": 120,
      "text": "훨씬 복합적입니다.",
      "start_ms": 369245,
      "end_ms": 372269
    },
    {
      "idx": 121,
      "text": "**소득 여건**,",
      "start_ms": 372269,
      "end_ms": 375293
    },
    {
      "idx": 122,
      "text": "**대출 가능성**,",
      "start_ms": 375293,
      "end_ms": 378620
    },
    {
      "idx": 123,
      "text": "**지역 수요**,",
      "start_ms": 378620,
      "end_ms": 381644
    },
    {
      "idx": 124,
      "text": "**정책 해석**이",
      "start_ms": 381644,
      "end_ms": 384668
    },
    {
      "idx": 125,
      "text": "함께 움직입니다.",
      "start_ms": 384668,
      "end_ms": 387390
    },
    {
      "idx": 126,
      "text": "그래서 지금은",
      "start_ms": 387390,
      "end_ms": 389507
    },
    {
      "idx": 127,
      "text": "한 줄 전망보다,",
      "start_ms": 389507,
      "end_ms": 392229
    },
    {
      "idx": 128,
      "text": "내 지역이 어느 시나리오에",
      "start_ms": 392229,
      "end_ms": 396463
    },
    {
      "idx": 129,
      "text": "들어가는지 보는 게",
      "start_ms": 396463,
      "end_ms": 399487
    },
    {
      "idx": 130,
      "text": "훨씬 중요합니다.",
      "start_ms": 399487,
      "end_ms": 402209
    },
    {
      "idx": 131,
      "text": "정리하겠습니다.",
      "start_ms": 402209,
      "end_ms": 404628
    },
    {
      "idx": 132,
      "text": "5월 9일 이후 집값의 핵심은,",
      "start_ms": 404628,
      "end_ms": 409769
    },
    {
      "idx": 133,
      "text": "상승이냐 하락이냐를",
      "start_ms": 409769,
      "end_ms": 412793
    },
    {
      "idx": 134,
      "text": "한 단어로 답하는 게",
      "start_ms": 412793,
      "end_ms": 416120
    },
    {
      "idx": 135,
      "text": "아닙니다.",
      "start_ms": 416120,
      "end_ms": 417632
    },
    {
      "idx": 136,
      "text": "금리 동결은",
      "start_ms": 417632,
      "end_ms": 419446
    },
    {
      "idx": 137,
      "text": "바닥을 받쳐줄 수 있습니다.",
      "start_ms": 419446,
      "end_ms": 423982
    },
    {
      "idx": 138,
      "text": "하지만 규제와 대출 신호에 따라,",
      "start_ms": 423982,
      "end_ms": 429426
    },
    {
      "idx": 139,
      "text": "살아나는 지역과",
      "start_ms": 429426,
      "end_ms": 431845
    },
    {
      "idx": 140,
      "text": "눌리는 지역은",
      "start_ms": 431845,
      "end_ms": 433962
    },
    {
      "idx": 141,
      "text": "더 또렷하게 갈릴 수 있습니다.",
      "start_ms": 433962,
      "end_ms": 439103
    },
    {
      "idx": 142,
      "text": "앞으로 더 중요해지는 건",
      "start_ms": 439103,
      "end_ms": 443034
    },
    {
      "idx": 143,
      "text": "평균 가격이 아닙니다.",
      "start_ms": 443034,
      "end_ms": 446663
    },
    {
      "idx": 144,
      "text": "**거래량**,",
      "start_ms": 446663,
      "end_ms": 449082
    },
    {
      "idx": 145,
      "text": "**대출 흐름**,",
      "start_ms": 449082,
      "end_ms": 452106
    },
    {
      "idx": 146,
      "text": "**정책 메시지**,",
      "start_ms": 452106,
      "end_ms": 455433
    },
    {
      "idx": 147,
      "text": "**지역별 수급**을",
      "start_ms": 455433,
      "end_ms": 458760
    },
    {
      "idx": 148,
      "text": "같이 봐야 합니다.",
      "start_ms": 458760,
      "end_ms": 461784
    },
    {
      "idx": 149,
      "text": "결국 시장은 평균이 아니라,",
      "start_ms": 461784,
      "end_ms": 466320
    },
    {
      "idx": 150,
      "text": "차이에서 움직입니다.",
      "start_ms": 466320,
      "end_ms": 469647
    },
    {
      "idx": 151,
      "text": "여러분 지역은 지금",
      "start_ms": 469647,
      "end_ms": 472671
    },
    {
      "idx": 152,
      "text": "어떤 영향을 받고 있나요.",
      "start_ms": 472671,
      "end_ms": 476905
    },
    {
      "idx": 153,
      "text": "댓글로 남겨주세요.",
      "start_ms": 476905,
      "end_ms": 479929
    }
  ]
}
    {
      "idx": 44,
      "text": "거래가 꾸준히 쌓이는 시점입니다.",
      "start_ms": 213884,
      "end_ms": 219314
    },
    {
      "idx": 45,
      "text": "이게 훨씬 중요합니다.",
      "start_ms": 219314,
      "end_ms": 222934
    },
    {
      "idx": 46,
      "text": "만약 거래량은 받쳐주지 않는데,",
      "start_ms": 222934,
      "end_ms": 228062
    },
    {
      "idx": 47,
      "text": "가격만 일부 오른다면",
      "start_ms": 228062,
      "end_ms": 231380
    },
    {
      "idx": 48,
      "text": "어떻게 봐야 할까요?",
      "start_ms": 231380,
      "end_ms": 234698
    },
    {
      "idx": 49,
      "text": "그건 시장 전체의 추세 전환이라기보다,",
      "start_ms": 234698,
      "end_ms": 241033
    },
    {
      "idx": 50,
      "text": "일부 지역이나 특정 단지 중심의",
      "start_ms": 241033,
      "end_ms": 246161
    },
    {
      "idx": 51,
      "text": "국지적 반등일 가능성이 큽니다.",
      "start_ms": 246161,
      "end_ms": 251289
    },
    {
      "idx": 52,
      "text": "그래서 가격 숫자 하나만 보면 안 됩니다.",
      "start_ms": 251289,
      "end_ms": 258228
    },
    {
      "idx": 53,
      "text": "경제와 부동산을 같이 보면",
      "start_ms": 258228,
      "end_ms": 262451
    },
    {
      "idx": 54,
      "text": "더 잘 보입니다.",
      "start_ms": 262451,
      "end_ms": 265166
    },
    {
      "idx": 55,
      "text": "금리 인하는 분명",
      "start_ms": 265166,
      "end_ms": 267881
    },
    {
      "idx": 56,
      "text": "자산시장에 우호적인 신호일 수 있습니다.",
      "start_ms": 267881,
      "end_ms": 274518
    },
    {
      "idx": 57,
      "text": "하지만 그 효과가 제대로 나오려면",
      "start_ms": 274518,
      "end_ms": 279948
    },
    {
      "idx": 58,
      "text": "조건이 더 필요합니다.",
      "start_ms": 279948,
      "end_ms": 283568
    },
    {
      "idx": 59,
      "text": "**유동성**이 따라와야 하고,",
      "start_ms": 283568,
      "end_ms": 288696
    },
    {
      "idx": 60,
      "text": "대출 접근성이 살아나야 하고,",
      "start_ms": 288696,
      "end_ms": 293523
    },
    {
      "idx": 61,
      "text": "소비와 고용에 대한 안정감도 있어야 합니다.",
      "start_ms": 293523,
      "end_ms": 300763
    },
    {
      "idx": 62,
      "text": "경기 불확실성이 큰데",
      "start_ms": 300763,
      "end_ms": 304081
    },
    {
      "idx": 63,
      "text": "금리만 조금 내린다고 해서,",
      "start_ms": 304081,
      "end_ms": 308606
    },
    {
      "idx": 64,
      "text": "사람들 지갑이 바로 열리지는 않습니다.",
      "start_ms": 308606,
      "end_ms": 314941
    },
    {
      "idx": 65,
      "text": "결국 부동산은",
      "start_ms": 314941,
      "end_ms": 317052
    },
    {
      "idx": 66,
      "text": "금융 변수, 심리 변수, 정책 변수가",
      "start_ms": 317052,
      "end_ms": 323085
    },
    {
      "idx": 67,
      "text": "함께 맞물려야",
      "start_ms": 323085,
      "end_ms": 325196
    },
    {
      "idx": 68,
      "text": "본격적인 상승 흐름이 나옵니다.",
      "start_ms": 325196,
      "end_ms": 330324
    },
    {
      "idx": 69,
      "text": "예를 들어 보겠습니다.",
      "start_ms": 330324,
      "end_ms": 333944
    },
    {
      "idx": 70,
      "text": "어떤 지역은",
      "start_ms": 333944,
      "end_ms": 335754
    },
    {
      "idx": 71,
      "text": "금리 인하 기대감 때문에",
      "start_ms": 335754,
      "end_ms": 339676
    },
    {
      "idx": 72,
      "text": "문의는 늘 수 있습니다.",
      "start_ms": 339676,
      "end_ms": 343598
    },
    {
      "idx": 73,
      "text": "하지만 실제 계약은 많지 않을 수 있습니다.",
      "start_ms": 343598,
      "end_ms": 350838
    },
    {
      "idx": 74,
      "text": "반대로 실수요가 꾸준하고,",
      "start_ms": 350838,
      "end_ms": 355061
    },
    {
      "idx": 75,
      "text": "공급 부담이 적은 지역은",
      "start_ms": 355061,
      "end_ms": 358983
    },
    {
      "idx": 76,
      "text": "거래량이 먼저 살아날 수 있습니다.",
      "start_ms": 358983,
      "end_ms": 364715
    },
    {
      "idx": 77,
      "text": "그리고 그 뒤에 가격이 따라갈 수 있습니다.",
      "start_ms": 364715,
      "end_ms": 371955
    },
    {
      "idx": 78,
      "text": "그래서 지금은",
      "start_ms": 371955,
      "end_ms": 374066
    },
    {
      "idx": 79,
      "text": "뉴스 헤드라인보다 더 중요한 게 있습니다.",
      "start_ms": 374066,
      "end_ms": 381005
    },
    {
      "idx": 80,
      "text": "내가 보는 지역의 거래량이 늘고 있는지,",
      "start_ms": 381005,
      "end_ms": 387642
    },
    {
      "idx": 81,
      "text": "대출이 실제로 가능한지,",
      "start_ms": 387642,
      "end_ms": 391564
    },
    {
      "idx": 82,
      "text": "매도자와 매수자의 기대 가격 차이가",
      "start_ms": 391564,
      "end_ms": 397296
    },
    {
      "idx": 83,
      "text": "줄고 있는지,",
      "start_ms": 397296,
      "end_ms": 399407
    },
    {
      "idx": 84,
      "text": "이걸 봐야 합니다.",
      "start_ms": 399407,
      "end_ms": 402423
    },
    {
      "idx": 85,
      "text": "그게 진짜 시장 신호에 더 가깝습니다.",
      "start_ms": 402423,
      "end_ms": 408758
    },
    {
      "idx": 86,
      "text": "정리해보겠습니다.",
      "start_ms": 408758,
      "end_ms": 411473
    },
    {
      "idx": 87,
      "text": "지금 시장은",
      "start_ms": 411473,
      "end_ms": 413283
    },
    {
      "idx": 88,
      "text": "금리 인하 기대만으로",
      "start_ms": 413283,
      "end_ms": 416601
    },
    {
      "idx": 89,
      "text": "집값이 바로 오르는 구조가 아닙니다.",
      "start_ms": 416601,
      "end_ms": 422634
    },
    {
      "idx": 90,
      "text": "금리도 중요합니다.",
      "start_ms": 422634,
      "end_ms": 425650
    },
    {
      "idx": 91,
      "text": "하지만 더 중요한 건",
      "start_ms": 425650,
      "end_ms": 428968
    },
    {
      "idx": 92,
      "text": "**거래량**, **대출규제**, **시장심리**입니다.",
      "start_ms": 428968,
      "end_ms": 438320
    },
    {
      "idx": 93,
      "text": "앞으로 시장을 볼 때는",
      "start_ms": 438320,
      "end_ms": 441940
    },
    {
      "idx": 94,
      "text": "금리 뉴스 하나에 흔들리기보다,",
      "start_ms": 441940,
      "end_ms": 447068
    },
    {
      "idx": 95,
      "text": "거래가 실제로 붙는지,",
      "start_ms": 447068,
      "end_ms": 450688
    },
    {
      "idx": 96,
      "text": "자금이 움직일 수 있는지,",
      "start_ms": 450688,
      "end_ms": 454911
    },
    {
      "idx": 97,
      "text": "심리가 회복되는지를 같이 보셔야 합니다.",
      "start_ms": 454911,
      "end_ms": 461548
    },
    {
      "idx": 98,
      "text": "그래야 지금 시장을",
      "start_ms": 461548,
      "end_ms": 464564
    },
    {
      "idx": 99,
      "text": "훨씬 더 정확하게 읽을 수 있습니다.",
      "start_ms": 464564,
      "end_ms": 470597
    },
    {
      "idx": 100,
      "text": "여러분 지역은 어떤 영향을 받고 있는지",
      "start_ms": 470597,
      "end_ms": 476932
    },
    {
      "idx": 101,
      "text": "댓글로 남겨주세요.",
      "start_ms": 476932,
      "end_ms": 479948
    }
  ]
}